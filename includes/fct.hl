#ifdef min
#undef min
template<class T>
T min(T v1,T v2) { return iif(v1<v2,v1,v2); }
#endif

#ifdef asinh
#undef asinh
Ldbl asinh(Ldbl x);
Ldbl asinh(Ldbl x)
{
 Ldbl r;
 if(fabsl(x)<1e2466) r=logl(x+sqrtl(pw2(x)+1.));
 else
 {
  if(0.<x) r=Ln2+logl(x);
  else r=-1.17e4932;
 }
 return r;
}
#endif

#ifdef acosh
#undef acosh
Ldbl acosh(Ldbl x);
Ldbl acosh(Ldbl x)
{
 Ldbl r;
 if(x<1.) r=0.;
 else
 {
  if(x<1e2466) r=logl(x+sqrtl(pw2(x)-1.));
  else r=Ln2+logl(x);
 }
 return r;
}
#endif

#ifdef atanh
#undef atanh
Ldbl atanh(Ldbl x);
Ldbl atanh(Ldbl x)
{
 Ldbl r;
 if((-1.<x)&&(x<1.)) r=logl((1.+x)/(1.-x))/2.;
 else r=-1.17e4932;
 return r;
}
#endif

#ifdef nombre
#undef nombre
void nombre(Ldbl v);
void nombre(Ldbl v)
{
 fractionL=modfl(v,&entierL);
}
#endif

#ifdef number
#undef number
void number(Ldbl v);
void number(Ldbl v)
{
 if(v!=0.)
 {
  fractionL=modfl(log10l(fabsl(v)),&exposantL);
  if(fractionL<0.) fractionL++,exposantL--;
  mantisseL=powl(10.,fractionL);
  if(v<0.) mantisseL=-mantisseL;
 }
 else mantisseL=0.,exposantL=0.;
}
#endif

#ifdef number2
#undef number2
void number2(Ldbl v);
void number2(Ldbl v)
{
 int expo;
 mantisseL=frexpl(v,&expo);
 exposantL=(Ldbl)expo;
}
#endif

#define arondi(fct,v,a) (fct(1e##a*v)/1e##a)

#ifdef intg
#undef intg
Ldbl intg(Ldbl v);
#define intg_(v,i) (intg(v*1e##i)/1e##i)
Ldbl intg(Ldbl v)
{
 if(v>0.) v=floorl(v);
 else v=ceill(v);
 return v;
}
#endif

#ifdef rnd
#undef rnd
Ldbl rnd(Ldbl v);
#define rnd_(v,r) (rnd(v*1e##r)/1e##r)
Ldbl rnd(Ldbl v)
{
 if(v<0.) v=floorl(v);
 else v=ceill(v);
 return v;
}
#endif

#ifdef round
#undef round
Ldbl round(Ldbl v,int r);
Ldbl round(Ldbl v,int r)
{
 v=pow10l(-r)*rnd(v*pow10l(r));
 return v;
}
#endif

#ifdef divs
#undef divs
Ldbl divs(Ldbl a,Ldbl b);
Ldbl divs(Ldbl a,Ldbl b)
{
 Ldbl v;
 if(a!=0)
 {
  if(b!=0.)
  {
   v=a/b;
   v+=(a-v*b)/b;
  }
  else
  {
   if(a<0.) v=-1.17e4932;
   else v=1.17e4932;
  }
 }
 else
 {
  if(b==0.) printf(" 0 / 0 impossible !\n"),getch(),exit(1);
 }
 return v;
}
#endif

#ifdef fact
#undef fact
Ldbl fact(Ldbl f);
Ldbl fact(Ldbl f)
{
 Ldbl v=1.;
 while(f!=1.) v*=f,f--;
 return v;
}
#endif

#ifdef rec
