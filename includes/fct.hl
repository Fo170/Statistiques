float TRGfst(float x);
float FSTsin(Ldbl x);
float FSTcos(Ldbl x);
//float FSTtan(Ldbl x);
//float FSTatan2(Ldbl y,Ldbl x);

float TRGfst(float x)
{
 return((1.014228085-(.04968101944+.121410965*x)*x)*x);
}
float FSTsin(Ldbl x)
{
 Ldbl abs;
 float s=1.;
 if(x<0.) s=-1.;
 abs=fmodl(fabsl(x),PIx2);
 if(M_PI<abs) abs-=M_PI,s*=-1.;
 if(M_PI_2<abs) abs=M_PI-abs;
 return(TRGfst(abs)*s);
}
float FSTcos(Ldbl x)
{
 return(FSTsin(x+M_PI_2));
}
