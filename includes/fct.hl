#ifdef MV
#undef MV
void MV(Ldbl xx,Ldbl yy,Ldbl zz,Ldbl ax,Ldbl ay,Ldbl az);
void MV(Ldbl xx,Ldbl yy,Ldbl zz,Ldbl ax,Ldbl ay,Ldbl az)
{
  Ldbl cs,sn,x,x1,y,y1,z,z1;
  x=xx,y=yy,z=zz;
  cs=cosl(ax),sn=sinl(ax);
  y1=y*cs+z*sn;
  z1=z*cs-y*sn;
  y=y1,z=z1;
  cs=cosl(ay),sn=sinl(ay);
  x1=x*cs+z*sn;
  z1=z*cs-x*sn;
  x=x1,V.z=z1;
  cs=cosl(az),sn=sinl(az);
  x1=x*cs+y*sn;
  y1=y*cs-x*sn;
  V.x=x1,V.y=y1;
}
#endif

#ifdef FAST_MV
#undef FAST_MV
void FAST_MV(Ldbl xx,Ldbl yy,Ldbl zz,Ldbl ax,Ldbl ay,Ldbl az);
void FAST_MV(Ldbl xx,Ldbl yy,Ldbl zz,Ldbl ax,Ldbl ay,Ldbl az)
{
  Ldbl cs,sn,x,x1,y,y1,z,z1;
  x=xx,y=yy,z=zz;
  cs=FSTcos(ax),sn=FSTsin(ax);
  y1=y*cs+z*sn;
  z1=z*cs-y*sn;
  y=y1,z=z1;
  cs=FSTcos(ay),sn=FSTsin(ay);
  x1=x*cs+z*sn;
  z1=z*cs-x*sn;
  x=x1,V.z=z1;
  cs=FSTcos(az),sn=FSTsin(az);
  x1=x*cs+y*sn;
  y1=y*cs-x*sn;
  V.x=x1,V.y=y1;
}
#endif

#ifdef T3D
#undef T3D
void T3D(Ldbl x,Ldbl y,Ldbl z);
void T3D(Ldbl x,Ldbl y,Ldbl z)
{
  Ldbl d;
  d=sqrtl(pw2(x)+pw2(y)+pw2((V.cz+z)));
  V.x=V.tx+V.cx+x*V.fc/d;
  V.y=V.ty+V.cy+y*V.fc/d;
}
#endif



