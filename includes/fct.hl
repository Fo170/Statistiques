Ldbl INTE(Ldbl *X,Ldbl *Y,ulong N)
{
 Ldbl a;
 ulong dn;
 a=_L(N-1+X)*_L(N-1+Y)-_L(X)*_L(Y);
 for(dn=1;dn<N;dn++)
   a+=_L(dn+X)*_L(dn-1+Y)-_L(dn-1+X)*_L(dn+Y);
 a/=2.;
 return a;
}
#endif

#ifdef SIMPSON
#undef SIMPSON
template<class T>
Ldbl SIMPSON(T *X,T *Y,ulong N)
{
 ulong i,Ni;
 Ldbl a,b,cf,S;
 if(N==2) S=(_L(X+1)-_L(X))*(_L(Y)+_L(Y+1))/2.;
 else
 {
  S=0.;
  Ni=N-fmodl(N,3);
  for(i=0;i<Ni;i+=3)
  {
	PRB(X+i,Y+i,&a,&b,&cf);
	S+=a*(pw3(_L(X+i+2))-pw3(_L(X+i)))/3.;
	S+=b*(pw2(_L(X+i+2))-pw2(_L(X+i)))/2.;
	S+=cf*(_L(X+i+2)-_L(X+i));
  }
  if(Ni!=N)
  {
	PRB(X+N-3,Y+N-3,&a,&b,&cf);
	S+=a*(pw3(_L(X+N-1))-pw3(_L(X+Ni)))/3.;
	S+=b*(pw2(_L(X+N-1))-pw2(_L(X+Ni)))/2.;
	S+=cf*(_L(X+N-1)-_L(X+Ni));
  }
 }
 return S;
}
#endif

#ifdef gauss
#undef gauss
template<class T>
void gauss(T *M,T *My,T *CF,ulong N)
{
 Ldbl k;
 ulong c,d,di,i,j,l,li,sq;
 if((CF=(T *)calloc(N,sizeof(T)))!=NULL)
 {
  for(sq=1;sq<N;sq++)
  {
   d=sq-1;
   for(l=sq;l<N;l++)
   {
	li=l*N,di=d*N;
	if(_L(d+di+M)==0.)
	{
	 for(j=d+1;j<N;j++)
	 {
	  k=_L(d+j*N+M);
	  if(k!=0.)
	  {
	   for(i=0;i<N;i++) swap(i+j*N+M,i+di+M);
	   swap(d+My,j+My),j=N;
	  }
	 }
	}
	if((_L(d+li+M)!=0.)&&(_L(d+di+M)!=0.))
	{
	 k=_L(d+li+M)/_L(d+di+M);
	 for(c=0;c<N;c++) _L(c+li+M)-=k*_L(c+di+M);
	 _L(My+l)-=k*_L(My+d);
	}
   }
  }
  for(l=N-1;l>=0;l--)
  {
   if(_L(M+l*(N+1))!=0.)
   {
	k=_L(My+l)/_L(M+l*(N+1));
	for(j=l;j>=0;j--) _L(My+j)-=k*_L(M+j*N+l);
   }
   else k=0.;
   _(CF+l)=(T)k;
  }
 }
 else
 {
  printf(" M‚moire insuffisante pour le tableau de Gauss\n");
  exit(1);
 }
}
#endif

#ifdef MC_LAURIN
#undef MC_LAURIN
template<class T>
void MC_LAURIN(T *X,T *Y,T *CF,ulong N)
{
 ulong c,l;
 Ldbl x;
 T *M;
 if((M=(T *)calloc(N*N,sizeof(T)))!=NULL)
 {
  for(l=0;l<N;l++)
  {
   _(N*l+M)=1.,x=_L(l+X),_(1+N*l+M)=(T)x;
   for(c=2;c<N;c++)
   {
	if(x!=0.) _L(c+N*l+M)=(T)powl(_L(l+X),(Ldbl)c);
	else _(c+N*l+M)=0.;
   }
  }
  gauss(M,Y,CF,N);
  free(M);
 }
 else
 {
  printf(" M‚moire insuffisante pour le tableau de MC Laurin\n");
  exit(1);
 }
}
#endif

