#ifdef swap
#undef swap
template<class T>
void swap(T *px,T *py)
{
 T tmp;
 tmp=P(px);
 P(px)=P(py);
 P(py)=tmp;
}
#endif

#ifdef sgn
#undef sgn
int sgn(Ldbl v);
int sgn(Ldbl v)
{
 int s;
 if(v==0.) s=0.;
 else
 {
  if(v<0.) s=-1.;
  else s=1.;
 }
 return s;
}
#endif

