 ulong dn;
 a=_L(N-1+X)*_L(N-1+Y)-_L(X)*_L(Y);
 for(dn=1;dn<N;dn++)
   a+=_L(dn+X)*_L(dn-1+Y)-_L(dn-1+X)*_L(dn+Y);
 a/=2.;
 return a;
