void pol(Ldbl m,Ldbl a)
{
 V.x=m*cosl(a);
 V.y=m*sinl(a);
}
#endif

#ifdef PRB
#undef PRB
template<class T>
void PRB(T *X,T *Y,Ldbl *a,Ldbl *b,Ldbl *cf)
{
 Ldbl x1,x2,x3,y1,y2,y3,dy1,dy2;
 x1=_L(X),x2=_L(X+1),x3=_L(X+2);
 y1=_L(Y),y2=_L(Y+1),y3=_L(Y+2);
 dy1=(y1-y2)/(x1-x2),dy2=(y2-y3)/(x2-x3);
 _(a)=(dy1-dy2)/(x1-x3);
 _(b)=dy1-_(a)*(x1+x2);
 _(cf)=y1-_(a)*pw2(x1)-_(b)*x1;
}
#endif

#ifdef det3
#undef det3
Ldbl det3(Ldbl a1,Ldbl b1,Ldbl c1,Ldbl a2,Ldbl b2,Ldbl c2,Ldbl a3,Ldbl b3,Ldbl c3);
Ldbl det3(Ldbl a1,Ldbl b1,Ldbl c1,Ldbl a2,Ldbl b2,Ldbl c2,Ldbl a3,Ldbl b3,Ldbl c3)
{
 Ldbl d;
 d=a1*b2*c3+b1*c2*a3+c1*a2*b3-a3*b2*c1-b3*c2*a1-c3*a2*b1;
 return d;
}
#endif

#ifdef Det3
#undef Det3
template<class T>
void Det3(T *X,T *Y,Ldbl *a,Ldbl *b,Ldbl *cf)
{
 Ldbl x1,px1,y1,x2,px2,y2,x3,px3,y3,d,da,db,dc;
 x1=_L(X),x2=_L(X+1),x3=_L(X+2);
 y1=_L(Y),y2=_L(Y+1),y3=_L(Y+2);
 px1=pw2(x1),px2=pw2(x2),px3=pw2(x3);
 d=det3(1.,x1,px1,1.,x2,px2,1.,x3,px3);
 dc=det3(y1,x1,px1,y2,x2,px2,y3,x3,px3);
 db=det3(1.,y1,px1,1.,y2,px2,1.,y3,px3);
 da=det3(1.,x1,y1,1.,x2,y2,1.,x3,y3);
 _(a)=da/d,_(b)=db/d,_(cf)=dc/d;
}
#endif

#ifdef rdich
#undef rdich
Ldbl rdich(Ldbl a,Ldbl b,Ldbl val);
Ldbl rdich(Ldbl a,Ldbl b,Ldbl val)
{
 Ldbl x,ya,yb,y;
 ya=ft(a),yb=ft(b);
 if(yb<ya) x=a,a=b,b=x;
 while(fabsl(y-val)>1e-100)
 {
  x=(a+b)/2.;
  y=ft(x);
  if(y<val) a=x;
  else b=x;
 }
 return x;
}
#endif

#ifdef INTE
#undef INTE
// INTEGRATION PAR LA METHODE DES TRAPEZES
/*template<class T>
Ldbl INTE(T *X,T *Y,ulong N)
{
